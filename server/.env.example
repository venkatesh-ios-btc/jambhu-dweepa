# Paste from Atlas → Connect → Drivers for THIS cluster only (hostname must match the cluster you opened).
# Include database name before ?, e.g.:
# mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/jambhu?retryWrites=true&w=majority&appName=App
# If password has @ : / # ? [ ] characters, URL-encode them (e.g. @ → %40).
# If connection fails: Atlas → Network Access → add current IP or 0.0.0.0/0 (dev), wait 1–2 min.
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/jambhu?retryWrites=true&w=majority&appName=App
PORT=5050

# Razorpay Dashboard → API Keys (same mode: both test rzp_test_* OR both live rzp_live_*)
# No spaces around =. One line each. If you see "Authentication failed", regenerate Key Secret in Dashboard and paste again.
RAZORPAY_KEY_ID=rzp_test_ScETXpe4N5sild
RAZORPAY_KEY_SECRET=J3i9FtOF8c8c94jqX8L2hWUA

# Ticket price in paise (10000 = ₹100)
TICKET_AMOUNT_PAISE=10000

# Optional: set to 1 to enable GET /payments/test-auth (checks Key ID + secret against Razorpay)
# RAZORPAY_DEBUG_AUTH=1
